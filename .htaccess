# ============================================================
# Root .htaccess
# Redirect all traffic to /public — the only publicly accessible directory.
# Direct access to app/, config/, core/, etc. is blocked by this redirect.
# ============================================================

Options -Indexes
Options -MultiViews

RewriteEngine On

# If the request is not already inside /public, redirect it there
# Local XAMPP path:
# RewriteCond %{REQUEST_URI} !^/clothy/public/
# RewriteRule ^(.*)$ /clothy/public/$1 [L,R=301]

# Production (InfinityFree):
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]
