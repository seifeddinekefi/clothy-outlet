# ============================================================
# Clothy Outlet - Environment Configuration
# ============================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit the .env file to version control!
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/clothy/public

# ─── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=clothy_outlet
DB_USER=your_db_user
DB_PASS=your_secure_password

# ─── Session ────────────────────────────────────────────────
SESSION_SECURE=false

# ─── Mail Configuration ─────────────────────────────────────
# For development, set MAIL_DRIVER=log to write emails to storage/logs/mail.log
# For production, use MAIL_DRIVER=smtp with proper SMTP settings
MAIL_DRIVER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Clothy Outlet"

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOCKOUT_MINUTES=15
RATE_LIMIT_RESET_ATTEMPTS=3
RATE_LIMIT_RESET_WINDOW_MINUTES=60
